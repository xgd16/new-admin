# 嵌入式在 monorepo 中时，上级 .gitignore 还会忽略 web-admin/dist、web-admin/dist.zip、.env.* 等。
# 此处保留独立克隆本目录时的常用规则。

# 依赖与构建产物
node_modules
dist
dist-ssr
dist.zip

# 本地覆盖（Vite）
*.local

# 日志
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 编辑器
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 系统文件
.DS_Store
