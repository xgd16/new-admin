# 可选：覆盖配置（Viper 前缀 NEW_ADMIN_，嵌套键用下划线）
# NEW_ADMIN_SERVER_ADDR=:9090
# NEW_ADMIN_LOG_LEVEL=debug
# NEW_ADMIN_LOG_FILE_PATH=logs/new-admin-{2006-01-02_15-04-05}.log
# NEW_ADMIN_LOG_FILE_ERROR_PATH=logs/new-admin-error-{2006-01-02_15-04-05}.log
# NEW_ADMIN_LOG_CONSOLE_ENABLED=true
# NEW_ADMIN_LOG_ACCESS_LOG_FILE_ENABLED=true
# NEW_ADMIN_LOG_FILE_ENABLED=true
# NEW_ADMIN_LOG_FILE_FORMAT=json
# NEW_ADMIN_LOG_CALLER_ENABLED=true
# NEW_ADMIN_LOG_STACKTRACE_LEVEL=error
# NEW_ADMIN_LOG_FILE_MAX_SIZE=50M      # 推荐：带单位；与 NEW_ADMIN_LOG_FILE_MAX_MEGABYTES 同时存在时以前者为准
# NEW_ADMIN_LOG_FILE_MAX_MEGABYTES=100
# NEW_ADMIN_LOG_FILE_MAX_BACKUPS=7
# NEW_ADMIN_LOG_FILE_MAX_AGE_DAYS=28
# NEW_ADMIN_LOG_FILE_COMPRESS=false

# 数据库与缓存（推荐生产用环境变量注入密码，勿提交真实密钥）
# NEW_ADMIN_MYSQL_PASSWORD=486213
# JWT（生产必填强密钥）
# NEW_ADMIN_JWT_SECRET=your-long-random-string

# 静态文件：本地目录；可覆盖 config.yaml 中 static.*
# NEW_ADMIN_STATIC_UPLOAD_ROOT=data/uploads
# NEW_ADMIN_STATIC_PUBLIC_ROOT=data/public

# 数据库种子默认管理员账号（迁移 000002）：admin / admin123 — 仅限开发，请及时改密

